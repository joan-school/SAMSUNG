PROJECT_1_VERSION=1

# Workspace 2: Rakshithas
ROBOFLOW_API_KEY_2=your_api_key_for_rakshithas_workspace
WORKSPACE_2_SLUG=rakshithas
PROJECT_2_SLUG=your_project_slug_here
PROJECT_2_VERSION=1