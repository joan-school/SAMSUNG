# Roboflow API Configuration - 2 Different API Keys
# Copy this file to .env and fill in your actual credentials

# Workspace 1: Joans
ROBOFLOW_API_KEY_1=your_api_key_for_joans_workspace
WORKSPACE_1_SLUG=joans
